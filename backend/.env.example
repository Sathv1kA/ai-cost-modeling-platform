# Copy to .env and edit as needed. Everything here is optional.

# CORS — comma-separated origins for the frontend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: default GitHub personal access token used when the client
# doesn't supply one. Avoids rate-limiting for unauthenticated scans.
# GITHUB_TOKEN=ghp_...

# Rate limit for POST /analyze — slowapi syntax, per client IP.
# Examples: "20/hour", "5/minute", "100/day"
RATE_LIMIT_ANALYZE=20/hour

# Sqlite cache DB path (relative to backend/ or absolute)
CACHE_DB_PATH=data/cache.db

# How many days to keep cached reports
CACHE_TTL_DAYS=30
